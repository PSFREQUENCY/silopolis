# ─── SILOPOLIS Environment Variables ──────────────────────────────────────────
# Copy to .env and fill in real values. NEVER commit .env to git.

# ── OnchainOS / OKX ────────────────────────────────────────────────────────────
ONCHAINOS_API_KEY=           # Get from https://web3.okx.com/onchainos/dev-portal
ONCHAINOS_PROJECT_ID=        # Your project ID from dev portal
ONCHAINOS_BASE_URL=https://www.okx.com

# ── X Layer Network ────────────────────────────────────────────────────────────
XLAYER_RPC_URL=https://rpc.xlayer.tech
XLAYER_TESTNET_RPC_URL=https://testrpc.xlayer.tech
XLAYER_CHAIN_ID=196
XLAYER_TESTNET_CHAIN_ID=195

# ── Agentic Wallet (NEVER share or commit private key) ─────────────────────────
AGENT_WALLET_ADDRESS=        # 0x... your Agentic Wallet address
AGENT_PRIVATE_KEY=           # WARNING: keep this secret, never expose

# ── Moltbook ───────────────────────────────────────────────────────────────────
MOLTBOOK_API_KEY=            # moltbook_sk_... from registration
MOLTBOOK_BASE_URL=https://www.moltbook.com

# ── Claude / Anthropic ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=           # sk-ant-... from https://console.anthropic.com

# ── SILOPOLIS Config ───────────────────────────────────────────────────────────
SILOPOLIS_MAX_SPEND_PER_DAY_USD=50.00     # Daily spend cap
SILOPOLIS_MAX_GAS_GWEI=50                  # Max gas price willing to pay
SILOPOLIS_SWARM_SIZE=5                     # Number of concurrent agents
SILOPOLIS_RISK_LEVEL=medium               # low | medium | high
SILOPOLIS_LOG_LEVEL=INFO

# ── Deployed Contract Addresses ────────────────────────────────────────────────
AGENT_REGISTRY_ADDRESS=      # Set after deployment
REPUTATION_ENGINE_ADDRESS=   # Set after deployment
SKILL_MARKET_ADDRESS=        # Set after deployment
